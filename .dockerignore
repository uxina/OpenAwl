# ============================================
# Docker 构建忽略文件
# 排除不需要复制到镜像中的文件/目录
# ============================================

# 依赖目录（会在容器中重新安装）
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# 测试相关
tests
test-results
playwright-report
*.spec.js
*.test.js

# 开发工具配置
.git
.gitignore
.vscode
.idea
*.swp
*.swo
*~

# 文档（保留必要的，排除开发文档）
README.md
CHANGELOG.md
docs

# 环境配置（安全考虑，不复制到镜像）
.env
.env.local
.env.*.local

# 日志文件
logs
*.log

# 临时文件
tmp
temp
.tmp
*.tmp

# 操作系统文件
.DS_Store
Thumbs.db

# Docker 相关（避免递归）
Dockerfile*
docker-compose*
.dockerignore

# 构建输出
dist
build
coverage

# 其他不需要的文件
.github
.travis.yml
.eslintrc
.prettierrc
.editorconfig
